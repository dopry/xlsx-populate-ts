{
  "name": "@dopry/xlsx-populate-ts",
  "version": "0.0.0-semantic-release",
  "description": "Excel XLSX parser/generator written in TypeScript with Node.js and browser support, jQuery/d3-style method chaining, and a focus on keeping existing workbook features and styles intact.",
  "keywords": [
    "excel",
    "workbook",
    "xlsx",
    "parse",
    "generate",
    "populate",
    "template",
    "browser",
    "style",
    "formatting",
    "encryption",
    "password"
  ],
  "main": "dist/XlsxPopulate.js",
  "types": "dist/XlsxPopulate.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jasmine JASMINE_CONFIG_PATH=test/unit/jasmine.json",
    "e2e-generate": "jasmine JASMINE_CONFIG_PATH=test/e2e-generate/jasmine.json",
    "e2e-parse": "jasmine JASMINE_CONFIG_PATH=test/e2e-parse/jasmine.json",
    "test:windows": "npm-run-all test e2e-parse e2e-generate",
    "prepublishOnly": "npm run build"
  },
  "author": "Dave T. Johnson <dave@dtjohnson.net>",
  "contributors": [
    "Eddie Corrigall <eddiecorrigall@gmail.com>",
    "Alan Doyle <alandoyle95@gmail.com>"
  ],
  "license": "MIT",
  "dependencies": {
    "cfb": "^1.1.3",
    "jszip": "^3.2.2",
    "lodash": "^4.17.15",
    "sax": "^1.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dopry/xlsx-populate.git"
  },
  "bugs": "https://github.com/dopry/xlsx-populate/issues",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.3",
    "@types/sax": "^1.2.7",
    "edge-js": "^25.0.1",
    "glob": "^7.1.6",
    "jasmine": "^3.5.0",
    "jsondiffpatch": "^0.4.1",
    "npm-run-all": "^4.1.5",
    "proxyquire": "^2.1.3",
    "proxyquire-universal": "^2.1.0",
    "proxyquireify": "^3.2.1",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
